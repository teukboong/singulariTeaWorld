# Local-only deployment config. Copy to .env; never commit real secrets.

# Stable Workers.dev front door for ChatGPT custom app MCP URL:
# https://<worker>.workers.dev/mcp
SINGULARI_WORLD_FRONTDOOR_URL=https://singulari-world-frontdoor.<your-subdomain>.workers.dev

# Must match Worker secret ORIGIN_UPDATE_SECRET.
SINGULARI_WORLD_FRONTDOOR_UPDATE_SECRET=replace-with-random-secret

# Required by scripts/deploy_cloudflare_frontdoor.sh when wrangler.toml still
# contains the placeholder KV namespace id.
SINGULARI_WORLD_CF_KV_NAMESPACE_ID=replace-with-workers-kv-namespace-id

# Optional tunnel controls.
SINGULARI_WORLD_TUNNEL=cloudflared
SINGULARI_WORLD_TUNNEL_TARGET_URL=http://127.0.0.1:4187
SINGULARI_WORLD_TUNNEL_STATE_FILE=.runtime/mcp_tunnel_base_url.txt
SINGULARI_WORLD_TUNNEL_PENDING_FILE=.runtime/mcp_tunnel_origin_pending.txt

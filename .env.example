# Local-only deployment config. Copy to .env; never commit real secrets.

# Stable Workers.dev front door for ChatGPT custom app MCP URL:
# https://<worker>.workers.dev/mcp
SINGULARI_WORLD_FRONTDOOR_URL=https://singulari-world-frontdoor.<your-subdomain>.workers.dev

# Must match Worker secret ORIGIN_UPDATE_SECRET.
SINGULARI_WORLD_FRONTDOOR_UPDATE_SECRET=replace-with-random-secret

# Required by scripts/deploy_cloudflare_frontdoor.sh when wrangler.toml still
# contains the placeholder KV namespace id.
SINGULARI_WORLD_CF_KV_NAMESPACE_ID=replace-with-workers-kv-namespace-id

# Optional tunnel controls.
SINGULARI_WORLD_TUNNEL=cloudflared
SINGULARI_WORLD_TUNNEL_TARGET_URL=http://127.0.0.1:4187
SINGULARI_WORLD_TUNNEL_STATE_FILE=.runtime/mcp_tunnel_base_url.txt
SINGULARI_WORLD_TUNNEL_PENDING_FILE=.runtime/mcp_tunnel_origin_pending.txt

# Optional WebGPT backend controls for `singulari-world host-worker`.
# Default to the bundled wrapper so fresh clones do not depend on parent repos.
# SINGULARI_WORLD_TEXT_BACKEND=webgpt
# SINGULARI_WORLD_VISUAL_BACKEND=webgpt
# SINGULARI_WORLD_WEBGPT_TURN_CG_CADENCE_MIN=2
SINGULARI_WORLD_WEBGPT_MCP_WRAPPER=webgpt-mcp-checkout/scripts/webgpt-mcp.sh
# SINGULARI_WORLD_WEBGPT_PROFILE_ROOT=/Users/<user>/.hesperides/singulari-world/webgpt
# SINGULARI_WORLD_WEBGPT_MODEL=gpt-5.5
# SINGULARI_WORLD_WEBGPT_REASONING_LEVEL=high
# SINGULARI_WORLD_WEBGPT_TIMEOUT_SECS=900
# WebGPT text/image lanes must stay on separate browser sessions.
# SINGULARI_WORLD_WEBGPT_TEXT_CDP_PORT=9238
# SINGULARI_WORLD_WEBGPT_IMAGE_CDP_PORT=9239
# SINGULARI_WORLD_WEBGPT_TEXT_PROFILE_DIR=/Users/<user>/.hesperides/singulari-world/webgpt/text-profile
# SINGULARI_WORLD_WEBGPT_IMAGE_PROFILE_DIR=/Users/<user>/.hesperides/singulari-world/webgpt/image-profile
